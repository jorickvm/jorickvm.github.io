# Copy this file to `.env.local` and paste your API key there.
OPENAI_API_KEY=sk-...

# Cheap by default. You can raise quality or switch models later.
ATLASDAYS_IMAGE_MODEL=gpt-image-1-mini
ATLASDAYS_IMAGE_QUALITY=medium
ATLASDAYS_IMAGE_SIZE=1536x1024
ATLASDAYS_IMAGE_FORMAT=webp
ATLASDAYS_IMAGE_COMPRESSION=72
ATLASDAYS_IMAGE_BACKGROUND=opaque
ATLASDAYS_IMAGE_MODERATION=auto

# Default image counts.
ATLASDAYS_LEARN_IMAGE_COUNT=3
ATLASDAYS_HELP_IMAGE_COUNT=2
